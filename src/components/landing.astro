---
import dinosaur from "@/assets/denos/dinosaur.svg";
import diplodocus from "@/assets/denos/diplodocus.svg";
import triceratops from "@/assets/denos/triceratops.svg";
---

<div class="landing">
  <div class="landing-denos" aria-label="dinosaurios decorativos">
    <img src={dinosaur.src} alt="dino" width={180} height={180} />
    <img src={diplodocus.src} alt="diplo" width={180} height={180} />
    <img src={triceratops.src} alt="trice" width={180} height={180} />
  </div>
  <h2 class="landing-description">
    un pequeño proyecto nacido de mi fascinación por los dinosaurios y la
    historia de la tierra.
  </h2>
  <small class="landing-disclaimer">
    proyecto en desarrollo, contenido sujeto a cambios
  </small>
  <a href="/intro/sobre-mi/" class="landing-cta">explorar</a>
</div>

<style scoped>
  .landing {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - var(--sl-nav-height));
    gap: clamp(1.5rem, 4vh, 3rem);
    text-align: center;
    padding: 2rem;
    width: 100%;
  }

  .landing-denos {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: clamp(0.75rem, 4vw, 2rem);
    width: 100%;
  }

  .landing img {
    width: clamp(120px, 20vw, 220px);
    height: clamp(120px, 20vw, 220px);
    opacity: 0.85;
  }

  .landing-description {
    max-width: 600px;
    font-size: clamp(1.2rem, 2.5vw, 2rem);
    color: var(--sl-color-gray-2);
    line-height: 1.5;
    margin: 0;
  }

  .landing-cta {
    position: relative;
    display: inline-block;
    padding: 2.6rem 3.2rem 1.8rem;
    background-color: color-mix(
      in srgb,
      var(--sl-color-accent) 15%,
      transparent
    );
    border: none;
    border-radius: 0 0 50% 50% / 0 0 60% 60%;
    color: var(--sl-color-accent);
    text-decoration: none;
    font-size: var(--sl-text-xl);
    letter-spacing: 0.05em;
    transition:
      background-color 0.2s,
      color 0.2s;
    clip-path: polygon(
      0% 12%,
      10% 0%,
      20% 10%,
      30% 2%,
      42% 14%,
      54% 0%,
      65% 10%,
      76% 2%,
      88% 12%,
      100% 4%,
      100% 100%,
      0% 100%
    );
  }

  .landing-cta:hover {
    background-color: var(--sl-color-accent);
    color: var(--sl-color-black);
  }
  .landing-disclaimer {
    font-size: clamp(0.75rem, 1.5vw, 1rem);
    color: var(--sl-color-gray-3);
    margin: 0;
  }
</style>
